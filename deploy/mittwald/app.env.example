# Mittwald Zielprojekt: META-Regalbau / METAorder-v2
#
# Projekt-Short-ID: p-bbpye5
# Projekt-Domain:   https://p-bbpye5.project.space
# A-Record:         185.215.158.114
#
# GitHub Secrets (Repo META-Regalbau/METAorder-v2):
#   MITTWALD_API_TOKEN
#   MITTWALD_STACK_ID   <- Stack-UUID aus mStudio (Container → Stack → Details)
#   DATABASE_URL
#   SESSION_SECRET
#   ENCRYPTION_KEY
#
# GitHub Variable (empfohlen):
#   PUBLIC_APP_URL = https://p-bbpye5.project.space
#   (oder eigene Domain, sobald Ingress eingerichtet ist)

# Lokales Erst-Setup (mw stack deploy). CI nutzt GitHub Secrets + deploy/mittwald/stack.yaml.
APP_IMAGE=ghcr.io/meta-regalbau/metaorder-v2:latest
HOST_PORT=5000
PUBLIC_APP_URL=https://p-bbpye5.project.space

# Pflichtwerte
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME
SESSION_SECRET=replace-with-long-random-secret
ENCRYPTION_KEY=replace-with-long-random-secret

# Optional: Logging/Performance
REQUEST_LOG_SLOW_MS=1500

# Optional: Multi-Tenant/Integrationen
METAORDER_STRICT_TENANT=true
METAORDER_INTEGRATION_API_KEY=
METAORDER_INTEGRATION_USER_ID=
METAORDER_INTEGRATION_TENANT_ID=

# Optional: S3/MinIO fuer Ticket-Anhaenge
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_OBJECT_PREFIX=

# Optional: KI
COMMERCIAL_AGENT_ENABLED=true
COMMERCIAL_AGENT_WEB_VERIFY=false
AI_MODE=openai_optional

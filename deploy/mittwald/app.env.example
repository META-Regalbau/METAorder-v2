# Optional: Logging/Performance
REQUEST_LOG_SLOW_MS=1500

# Optional: Multi-Tenant/Integrationen
METAORDER_STRICT_TENANT=true
METAORDER_INTEGRATION_API_KEY=40d2e748-efdb-4dcf-9bed-26f3613f920f:TbmJIqO_REPXW9ZNQOjsEixf5PFvlKg7yor6o3xHs6U:mittwald_a
METAORDER_INTEGRATION_USER_ID=

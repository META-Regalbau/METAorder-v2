{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "pdf:landing-logo": "node scripts/generate-landing-logo-png.mjs",
    "openapi:generate": "node scripts/generate-openapi-paths.mjs",
    "build": "npm run openapi:generate && vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && esbuild scripts/resetRegulationPrice.ts scripts/importShopFakturen.ts --platform=node --packages=external --bundle --format=esm --outdir=dist/scripts && node scripts/copy-pdf-assets.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test:bom": "tsx scripts/testBillOfMaterials.ts",
    "test:eml": "tsx scripts/testEmlExtraction.ts",
    "test:cpq-units": "tsx scripts/testCpqUnits.ts",
    "test:cpq-core": "tsx scripts/testCpqCore.ts",
    "test:cross-sell-rule-engine": "tsx scripts/testCrossSellRuleEngine.ts",
    "test:cross-sell-shelving": "tsx scripts/testCrossSellShelvingHeuristics.ts",
    "test:line-item-screening": "tsx scripts/testLineItemProductScreening.ts",
    "test:person-name": "tsx scripts/testPersonNameNormalize.ts",
    "test:meta-blocklist": "tsx scripts/testMetaCompanyBlocklist.ts",
    "test:company-name-heuristics": "tsx scripts/testCompanyNameHeuristics.ts",
    "test:strict-auto-create": "tsx scripts/testCommercialStrictAutoCreate.ts",
    "test:gmail-ingest-hint": "tsx scripts/testGmailIntentHintIngest.ts",
    "test:buyer-contact": "tsx scripts/testBuyerContactFieldUtils.ts",
    "test:order-pdf": "tsx scripts/testOrderPdfExtraction.ts",
    "check:openai": "tsx scripts/checkOpenai.ts",
    "check:cpq-data-quality": "tsx scripts/checkCpqDataQuality.ts",
    "reset:regulation-price": "node dist/scripts/resetRegulationPrice.js",
    "reset:regulation-price:dev": "tsx scripts/resetRegulationPrice.ts",
    "import:shop-fakturen": "node dist/scripts/importShopFakturen.js",
    "import:shop-fakturen:dev": "tsx scripts/importShopFakturen.ts",
    "test:cpq-metacalc-payload": "tsx scripts/testCpqMetaCalcPayload.ts",
    "muster-mahnung": "tsx scripts/generateMusterMahnung.ts",
    "db:push": "node scripts/ensure-pgvector.mjs && drizzle-kit push --force",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:init:container": "node scripts/container-db-init.mjs",
    "classify-eml": "tsx scripts/classifyEmlIntent.ts",
    "commercial-agent:import-eml": "tsx scripts/ingestCommercialAgentEmailExemplars.ts",
    "seed:demo-products": "tsx scripts/seedDemoShopwareProducts.ts",
    "seed:demo-customers": "tsx scripts/seedDemoShopwareCustomers.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/tests/happy-path.spec.ts --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:performance:k6": "k6 run tests/performance/scenarios/happy-path.js --summary-export=tests/performance/reports/latest-summary.json",
    "test:security:zap": "docker run --rm -v $(pwd):/zap/wrk -t ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -c /zap/wrk/tests/security/zap-baseline.yaml -r /zap/wrk/tests/security/zap-report.html -J /zap/wrk/tests/security/zap-report.json",
    "test:lighthouse:ci": "lhci autorun"
  },
